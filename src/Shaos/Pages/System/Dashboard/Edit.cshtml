@page
@model Shaos.Pages.System.Dashboard.EditModel

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<h1>Edit</h1>

<h4>Dashboard Item</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Item.Label" class="control-label"></label>
                <input asp-for="Item.Label" class="form-control" />
                <select asp-for="Item.Parameter.Id" class="form-control"
                        asp-items="@Model.ParametersList">
                    <option value="">-- Select Parameter --</option>
                </select>
                <span asp-validation-for="Item.Label" class="text-danger"></span>
            </div>
            <input type="hidden" asp-for="Item.Id" />
            <div class="form-group">
                <button type="submit" class="btn btn-sm btn-success">
                    <span>
                        <svg bootstrap-icon="Floppy" width="18" height="18" aria-label="Save"></svg>
                    </span>
                </button>
                <a asp-page="./Index" class="btn btn-sm btn-primary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
