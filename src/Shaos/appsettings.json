{
  "ApplicationOptions": {
    "DashboardItemsWidth": 2,
    "PageSize": 5
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=shaos.db;"
  },
  "FileStoreOptions": {
    "BinariesPath": "F:\\temp\\Shaos\\Binaries",
    "PackagesPath": "F:\\temp\\Shaos\\Packages"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore.Hosting": "Warning",
        "Microsoft.AspNetCore.Http.Connections": "Debug",
        "Microsoft.AspNetCore.Mvc": "Debug",
        "Microsoft.AspNetCore.Routing": "Debug",
        "System": "Debug"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}
