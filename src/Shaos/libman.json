{
  "version": "3.0",
  "defaultProvider": "unpkg",
  "libraries": [
    {
      "library": "chart.js@latest",
      "destination": "wwwroot/lib/chart.js"
    },
    {
      "provider": "unpkg",
      "library": "chartjs-plugin-streaming@latest",
      "destination": "wwwroot/lib/chartjs-plugin-streaming/"
    },
    {
      "provider": "cdnjs",
      "library": "moment.js@2.30.1",
      "destination": "wwwroot/lib/moment.js/"
    }
  ,
{
  "provider": "unpkg",
  "library": "chartjs-adapter-moment@latest",
  "destination": "wwwroot/lib/chartjs-adapter-moment/"
}
]
}